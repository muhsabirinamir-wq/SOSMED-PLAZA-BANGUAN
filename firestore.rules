rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if true; // Allow teammates to see user lists to assign tasks & identify reporter
      allow create, update, delete: if request.auth != null;
    }

    // 3. Todos Collection
    match /todos/{todoId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // 4. Social Media Records Collection
    match /sosmedRecords/{recordId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // 5. Omset (Revenue) Records Collection
    match /omsetRecords/{recordId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // 6. Activity (Audit) Logs Collection - Strictly Immutable
    match /activityLogs/{logId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // Once written, activity logs are immutable!
    }

    // 7. General Settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
