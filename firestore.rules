rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read, write: if true; // Allow client queries and seed actions without anonymous auth restrictions
    }

    // 3. Todos Collection
    match /todos/{todoId} {
      allow read, write: if true;
    }

    // 4. Social Media Records Collection
    match /sosmedRecords/{recordId} {
      allow read, write: if true;
    }

    // 5. Omset (Revenue) Records Collection
    match /omsetRecords/{recordId} {
      allow read, write: if true;
    }

    // 6. Activity (Audit) Logs Collection - Strictly Immutable
    match /activityLogs/{logId} {
      allow read, write: if true;
    }

    // 7. General Settings
    match /settings/{docId} {
      allow read, write: if true;
    }

    // 8. Connection Test Collection
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
